{
    "name": "@plurnk/plurnk-mimetypes-text-nix",
    "version": "0.2.2",
    "description": "text/x-nix mimetype handler for plurnk-service. Tier 2: tree-sitter-nix grammar built to WASM and shipped pre-built. Covers flakes, derivations, attrsets, let-expressions, and lambdas.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "text/x-nix",
                "glyph": "❄️",
                "extensions": [
                    ".nix"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json",
        "./nix.wasm": "./nix.wasm"
    },
    "files": [
        "dist/**/*",
        "nix.wasm",
        ".nix-grammar-pin",
        "README.md"
    ],
    "scripts": {
        "build:wasm": "node scripts/build-wasm.mjs",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "prepare": "npm run build && (git config core.hooksPath .githooks || true)",
        "verify:wasm": "node scripts/verify-wasm.mjs",
        "deps:fresh": "npm outdated",
        "prepublishOnly": "npm run deps:fresh && npm audit --audit-level=moderate && npm test"
    },
    "dependencies": {
        "web-tree-sitter": "^0.26.9"
    },
    "devDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.0 || ^0.16.0",
        "@types/node": "^26.0.0",
        "tree-sitter-cli": "^0.26.9",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.16.0"
    }
}
